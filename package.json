{
  "name": "trading-analysis-platform",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/parse-report.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/parse-report.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:trading-analysis-platform": "node dist/trading-analysis-platform/server/server.mjs",
    "prepare": "husky",
    "lint": "ng lint",
    "test:scripts": "vitest run --config scripts/vitest.config.mjs"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.1",
    "express": "^5.1.0",
    "lightweight-charts": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.3.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.3",
    "prettier": "3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8",
    "xlsx": "^0.18.5"
  }
